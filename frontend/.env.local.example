# Copy this file to `.env.local` and fill in. Next.js only reads env files from
# the frontend directory, so this must live here (not at the repo root).
# NEVER commit a real `.env.local`.

# --- Wallet / RPC ---
# https://dashboard.alchemy.com/ — Sepolia HTTPS key
NEXT_PUBLIC_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY

# https://cloud.walletconnect.com/ — create a project, copy the Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WC_PROJECT_ID

# --- Deployed contract addresses ---
# These come from `deployments/sepolia.json` after you run
#   forge script script/Deploy.s.sol:Deploy --broadcast --verify

# Block the IntentAuction was first deployed at. Used by the frontend to
# scope `eth_getLogs` queries. Required on RPCs that cap getLogs ranges
# (e.g. Alchemy free tier caps it to 10 blocks).
NEXT_PUBLIC_DEPLOY_BLOCK=0

NEXT_PUBLIC_INTENT_AUCTION_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_WETH_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_SWAP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_LENDING_ADDRESS=0x0000000000000000000000000000000000000000

# --- Optional ---
# If set, a "source" link appears in the site footer. Leave unset to hide it.
# NEXT_PUBLIC_GITHUB_URL=https://github.com/your-handle/intent-auction
