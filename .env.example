# Copy this to .env and fill in. NEVER commit a real .env.

# -- Smart contracts (Foundry) --
# RPC URL for Sepolia (Alchemy, Infura, or other)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Mainnet RPC (only needed for forked tests, optional)
MAINNET_RPC_URL=https://eth.llamarpc.com

# Deployer private key (TESTNET ONLY — never use a key holding real funds)
PRIVATE_KEY=0xaaaa...

# Etherscan API key (for contract verification). Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# -- Frontend (Next.js) --
# Frontend env vars live in `frontend/.env.local` — see `frontend/.env.local.example`.
# Do NOT duplicate NEXT_PUBLIC_* here: if you `source .env` before `npm run dev`,
# those shell vars will override `.env.local` and break the UI.
